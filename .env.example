# Database
# Connect to PostgreSQL using your preferred hosting (Supabase, Neon, Docker, etc.)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/corely_lite?schema=public"

# Supabase Auth / Storage (Optional placeholders)
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
